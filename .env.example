# ─── Required ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Agent identity ──────────────────────────────────────────────────────────
# Selects the local memory namespace. Change to isolate different agent profiles.
AGENT_ID=local_agent

# Required by main.py (FastAPI worker) to identify the session user.
USER_ID=local_user

# ─── Memory storage ──────────────────────────────────────────────────────────
# Root folder for local FAISS/JSON memory stores. Defaults to ./local_memory
LOCAL_MEMORY_ROOT=local_memory

# ─── Agent persona defaults (all optional) ───────────────────────────────────
# Used only when local_memory/<AGENT_ID>/agent_identity.json has not overridden them.
AGENT_NAME=My_Quarq_Agent
AGENT_PERSONALITY="friendly,joyful"
AGENT_USE_CASES=["coding","brainstorming","code review"]
AGENT_CUSTOM_PROMPT="You have a world best memory system"
# AGENT_IDENTITY_CONFIG_PATH=local_memory/local_agent/agent_identity.json

# ─── CLI display (optional) ──────────────────────────────────────────────────
# Shown in the control console header/footer.
QUARQ_AGENT_VERSION=v0.4.1
QUARQ_MODEL_LABEL=gpt-4.1
# QUARQ_REASONING_EFFORT=xhigh
# AGENT_DEBUG=false

# ─── Channel integrations (optional) ─────────────────────────────────────────
# Telegram: create a bot with @BotFather, add your user ID, then run:
# /connect telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_WEBHOOK_SECRET=change_this_to_a_random_secret
