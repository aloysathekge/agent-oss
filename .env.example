# ─── Required ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Agent identity ──────────────────────────────────────────────────────────
# Selects the local memory namespace. Change to isolate different agent profiles.
AGENT_ID=local_agent

# Required by main.py (FastAPI worker) to identify the session user.
USER_ID=local_user

# ─── Memory storage ──────────────────────────────────────────────────────────
# Root folder for local FAISS/JSON memory stores. Defaults to ./local_memory
LOCAL_MEMORY_ROOT=local_memory
# Optional override for durable channel chat history and attachment storage.
# Defaults to local_memory/<AGENT_ID>/channel_state
# LOCAL_CHANNEL_STORAGE_ROOT=local_memory/local_agent/channel_state
# Max accepted channel attachment size in bytes. Defaults to 20 MB.
# CHANNEL_FILE_MAX_BYTES=20000000
# Max extracted text passed from attachments into an agent turn.
# ATTACHMENT_EXTRACT_MAX_CHARS=24000
# Optional OpenAI models for image description and audio transcription.
# MULTIMODAL_IMAGE_MODEL=gpt-4o-mini
# MULTIMODAL_AUDIO_MODEL=gpt-4o-mini-transcribe
# Max PDF pages rendered for vision fallback when embedded text extraction fails.
# PDF_VISION_MAX_PAGES=3

# ─── Agent persona defaults (all optional) ───────────────────────────────────
# Used only when local_memory/<AGENT_ID>/agent_identity.json has not overridden them.
AGENT_NAME=My_Quarq_Agent
AGENT_PERSONALITY="friendly,joyful"
AGENT_USE_CASES=["coding","brainstorming","code review"]
AGENT_CUSTOM_PROMPT="You have a world best memory system"
# AGENT_IDENTITY_CONFIG_PATH=local_memory/local_agent/agent_identity.json

# ─── CLI display (optional) ──────────────────────────────────────────────────
# Shown in the control console header/footer.
QUARQ_AGENT_VERSION=v0.4.4
QUARQ_MODEL_LABEL=gpt-4.1
# QUARQ_REASONING_EFFORT=xhigh
# AGENT_DEBUG=false

# ─── Cloud app tools (optional) ──────────────────────────────────────────────
# Required only when using external app actions such as GitHub, Gmail,
# Google Calendar, Slack, Notion, and Linear.
CLOUD_TOOLS_API_KEY=your_cloud_tools_api_key_here
CLOUD_TOOLKITS=github,gmail,googlecalendar,slack,notion,linear
# CLOUD_TOOLS_CACHE_DIR=local_memory/cloud_tools_cache
# CLOUD_TOOLS_CONFIG_PATH=local_memory/local_agent/agent_tools.json

# ─── Channel integrations (optional) ─────────────────────────────────────────
# Telegram: create a bot with @BotFather, add your user ID, then run:
# /connect telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_WEBHOOK_SECRET=change_this_to_a_random_secret
