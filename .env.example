# ─── Required ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Agent identity ──────────────────────────────────────────────────────────
# Selects the local memory namespace. Change to isolate different agent profiles.
AGENT_ID=local_agent

# Required by main.py (FastAPI worker) to identify the session user.
USER_ID=local_user

# ─── Memory storage ──────────────────────────────────────────────────────────
# Root folder for local FAISS/JSON memory stores. Defaults to ./local_memory
LOCAL_MEMORY_ROOT=local_memory

# ─── Agent persona (all optional) ────────────────────────────────────────────
AGENT_NAME=My_Quarq_Agent
AGENT_PERSONALITY="friendly,joyful"
AGENT_USE_CASES=["coding","brainstorming","code review"]
AGENT_CUSTOM_PROMPT="You have a world best memory system"

# ─── Tool integrations (only needed if using the corresponding skills) ────────
# Google OAuth desktop client JSON path (Gmail / Calendar skills)
# GMAIL_CREDENTIALS_PATH=credentials.json

# Google Cloud Storage (PDF generator skill)
# GCS_BUCKET_NAME=your_gcs_bucket
# GCS_PROJECT_ID=your_gcs_project_id

# Supabase (agent_identity_manager skill and legacy agent_v2/v3 variants)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
